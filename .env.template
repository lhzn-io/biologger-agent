# ==============================================================================
# Biologger Agent Stack Environment Configuration Template
# Copy this file to .env and configure variables for the target host
# ==============================================================================

# Target Model Configuration
DEFAULT_PROVIDER=vllm
DEFAULT_MODEL=google/gemma-4-26b-a4b-it

# VLM API base URL
# macOS: http://host.docker.internal:8080/v1 (native serving)
# NVIDIA/Linux: http://vllm-server:8000/v1 (containerized serving)
VLM_API_URL=http://host.docker.internal:8080/v1

# Local directories to mount inside the sandbox
BIOLOGGER_WORKSPACE_DIR=./workspace
BIOLOGGER_DATASETS_DIR=/Users/lhzn/Projects/whoi-mpg/datasets

# HuggingFace hub token (required for cloning/downloading private models or adapters)
HF_TOKEN=your_huggingface_token_here
HF_CACHE_DIR=~/.cache/huggingface
